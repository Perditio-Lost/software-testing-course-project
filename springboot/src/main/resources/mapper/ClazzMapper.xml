<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.ClazzMapper">

    <resultMap id="BaseResultMap" type="com.example.entity.Clazz">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="courseId" column="course_id"/>
        <result property="teacherId" column="teacher_id"/>
        <result property="courseName" column="courseName"/>
        <result property="teacherName" column="teacherName"/>
    </resultMap>

    <insert id="insert" parameterType="com.example.entity.Clazz" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO clazz
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null">name,</if>
            <if test="courseId != null">course_id,</if>
            <if test="teacherId != null">teacher_id,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="name != null">#{name},</if>
            <if test="courseId != null">#{courseId},</if>
            <if test="teacherId != null">#{teacherId},</if>
        </trim>
    </insert>

    <update id="updateById" parameterType="com.example.entity.Clazz">
        UPDATE clazz
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="courseId != null">course_id = #{courseId},</if>
            <if test="teacherId != null">teacher_id = #{teacherId},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM clazz WHERE id = #{id}
    </delete>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT
            c.id, c.name, c.course_id, c.teacher_id,
            co.name as courseName,
            t.name as teacherName
        FROM clazz c
        LEFT JOIN course co ON c.course_id = co.id
        LEFT JOIN teacher t ON c.teacher_id = t.id
        WHERE c.id = #{id}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT
            c.id, c.name, c.course_id, c.teacher_id,
            co.name as courseName,
            t.name as teacherName
        FROM clazz c
        LEFT JOIN course co ON c.course_id = co.id
        LEFT JOIN teacher t ON c.teacher_id = t.id
        <where>
            <if test="name != null and name != ''">
                AND LOWER(c.name) LIKE LOWER(CONCAT('%', #{name}, '%'))
            </if>
            <if test="courseId != null">
                AND c.course_id = #{courseId}
            </if>
            <if test="teacherId != null">
                AND c.teacher_id = #{teacherId}
            </if>
        </where>
        ORDER BY c.id DESC
    </select>

</mapper>
