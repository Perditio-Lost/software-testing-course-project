<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.TestClazzMapper">

    <insert id="insert" parameterType="com.example.entity.TestClazz" useGeneratedKeys="true">
        INSERT INTO test_clazz (test_id, clazz_id)
        VALUES (#{testId}, #{clazzId})
    </insert>

    <select id="selectByTestId" resultType="com.example.entity.TestClazz">
        SELECT id, test_id, clazz_id
        FROM test_clazz
        WHERE test_id = #{testId}
    </select>

    <select id="selectByClazzId" resultType="com.example.entity.TestClazz">
        SELECT id, test_id, clazz_id
        FROM test_clazz
        WHERE clazz_id = #{clazzId}
    </select>

</mapper>
