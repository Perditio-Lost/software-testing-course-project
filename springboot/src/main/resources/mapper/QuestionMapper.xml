<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.QuestionMapper">

    <resultMap id="QuestionResultMap" type="com.example.entity.Question">
        <id property="id" column="id"/>
        <result property="questionTypeId" column="question_type_id"/>
        <result property="courseId" column="course_id"/>
        <result property="teacherId" column="teacher_id"/>
        <result property="level" column="level"/>
        <result property="questionStem" column="question_stem"/>
        <result property="answer" column="answer"/>
        <result property="flag" column="flag"/>
        <result property="courseName" column="courseName"/>
        <result property="teacherName" column="teacherName"/>
        <result property="questionTypeName" column="questionTypeName"/>
        <result property="questionTypeVariety" column="questionTypeVariety"/>
        <collection property="choiceList" ofType="com.example.entity.Choice"
                    select="com.example.mapper.ChoiceMapper.selectByQuestionId"
                    column="id"/>
    </resultMap>

    <select id="selectAll" resultMap="QuestionResultMap">
        select
            question.*, course.name as courseName, teacher.name as teacherName,
            question_type.name as questionTypeName, question_type.variety as questionTypeVariety
        from `question`
        left join course on question.course_id = course.id
        left join teacher on question.teacher_id = teacher.id
        left join question_type on question.question_type_id = question_type.id
        <where>
            and (question.flag = 1 or question.flag is null)
            <if test="questionStem != null"> and LOWER(question.question_stem) like LOWER(concat('%', #{questionStem}, '%'))</if>
            <if test="teacherId != null"> and question.teacher_id = #{teacherId}</if>
            <if test="courseId != null"> and question.course_id = #{courseId}</if>
        </where>
    </select>

    <delete id="deleteById">
        delete from `question`
        where id = #{id}
    </delete>

    <!-- insert into question (username, password, ...) values ('question', 'question', ...) -->
    <insert id="insert" parameterType="com.example.entity.Question" useGeneratedKeys="true" keyProperty="id">
        insert into `question`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">id,</if>
            <if test="questionTypeId != null">question_type_id,</if>
            <if test="courseId != null">course_id,</if>
            <if test="teacherId != null">teacher_id,</if>
            <if test="level != null">level,</if>
            <if test="questionStem != null">question_stem,</if>
            <if test="answer != null">answer,</if>
            <if test="flag != null">flag,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="questionTypeId != null">#{questionTypeId},</if>
            <if test="courseId != null">#{courseId},</if>
            <if test="teacherId != null">#{teacherId},</if>
            <if test="level != null">#{level},</if>
            <if test="questionStem != null">#{questionStem},</if>
            <if test="answer != null">#{answer},</if>
            <if test="flag != null">#{flag},</if>
        </trim>
    </insert>

    <update id="updateById" parameterType="com.example.entity.Question">
        update `question`
        <set>
            <if test="questionStem != null">
                question_stem = #{questionStem},
            </if>
            <if test="courseId != null">
                course_id = #{courseId},
            </if>
            <if test="questionTypeId != null">
                question_type_id = #{questionTypeId},
            </if>
            <if test="level != null">
                level = #{level},
            </if>
            <if test="answer != null">
                answer = #{answer},
            </if>
            <if test="flag != null">
                flag = #{flag},
            </if>
        </set>
        where id = #{id}
    </update>

</mapper>