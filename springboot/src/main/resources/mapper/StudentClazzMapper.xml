<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.StudentClazzMapper">

    <insert id="insert" parameterType="com.example.entity.StudentClazz" useGeneratedKeys="true">
        insert into `student_clazz`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">id,</if>
            <if test="studentId != null">student_id,</if>
            <if test="clazzId != null">clazz_id,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="studentId != null">#{studentId},</if>
            <if test="clazzId != null">#{clazzId},</if>
        </trim>
    </insert>

    <select id="selectByStudentId" resultType="com.example.entity.StudentClazz">
        select * from student_clazz where student_id = #{studentId}
    </select>

    <select id="selectByClazzId" resultType="com.example.entity.StudentClazz">
        SELECT 
            sc.id,
            sc.student_id,
            sc.clazz_id,
            s.name as studentName,
            s.username as studentNumber,
            c.name as clazzName
        FROM student_clazz sc
        LEFT JOIN student s ON sc.student_id = s.id
        LEFT JOIN clazz c ON sc.clazz_id = c.id
        WHERE sc.clazz_id = #{clazzId}
        ORDER BY s.id ASC
    </select>

    <delete id="deleteById">
        delete from student_clazz where id = #{id}
    </delete>

    <delete id="deleteByStudentAndClazz">
        delete from student_clazz where student_id = #{studentId} and clazz_id = #{clazzId}
    </delete>

</mapper>
