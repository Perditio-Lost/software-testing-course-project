<view class="login-container data-v-b237504c"><view class="login-box data-v-b237504c"><view class="title data-v-b237504c">智考云</view><view class="subtitle data-v-b237504c">学生成绩查询</view><view class="form data-v-b237504c"><view class="form-item data-v-b237504c"><text class="label data-v-b237504c">用户名</text><input class="input data-v-b237504c" placeholder="请输入用户名" placeholder-style="color: #999" data-event-opts="{{[['input',[['__set_model',['$0','username','$event',[]],['formData']]]]]}}" value="{{formData.username}}" bindinput="__e"/></view><view class="form-item data-v-b237504c"><text class="label data-v-b237504c">密码</text><input class="input data-v-b237504c" password="{{true}}" placeholder="请输入密码" placeholder-style="color: #999" data-event-opts="{{[['input',[['__set_model',['$0','password','$event',[]],['formData']]]]]}}" value="{{formData.password}}" bindinput="__e"/></view><button class="login-btn data-v-b237504c" loading="{{loading}}" data-event-opts="{{[['tap',[['handleLogin',['$event']]]]]}}" bindtap="__e">{{''+(loading?'登录中...':'登录')+''}}</button></view></view></view>