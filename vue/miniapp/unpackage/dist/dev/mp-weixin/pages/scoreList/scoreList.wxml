<view class="score-list-container data-v-1f3c9430"><view class="header-card data-v-1f3c9430"><view class="user-info data-v-1f3c9430"><text class="greeting data-v-1f3c9430">{{"你好，"+(userInfo.name||'学生')}}</text><text class="student-no data-v-1f3c9430">{{"学号："+userInfo.username}}</text></view><view class="stat-info data-v-1f3c9430"><view class="stat-item data-v-1f3c9430"><text class="stat-value data-v-1f3c9430">{{total}}</text><text class="stat-label data-v-1f3c9430">考试总数</text></view></view></view><view class="exam-list data-v-1f3c9430"><block wx:if="{{$root.g0===0}}"><view class="empty-state data-v-1f3c9430"><text class="empty-icon data-v-1f3c9430">📝</text><text class="empty-text data-v-1f3c9430">暂无考试记录</text></view></block><block wx:for="{{$root.l0}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view data-event-opts="{{[['tap',[['viewPaper',['$0'],[[['examList','',index]]]]]]]}}" class="exam-card data-v-1f3c9430" bindtap="__e"><view class="exam-header data-v-1f3c9430"><text class="exam-name data-v-1f3c9430">{{item.$orig.test&&item.$orig.test.name||'-'}}</text><view class="{{['data-v-1f3c9430','status-badge',item.m0]}}">{{''+item.$orig.status+''}}</view></view><view class="exam-info data-v-1f3c9430"><view class="info-row data-v-1f3c9430"><text class="info-label data-v-1f3c9430">课程：</text><text class="info-value data-v-1f3c9430">{{item.$orig.test&&item.$orig.test.courseName||'-'}}</text></view><view class="info-row data-v-1f3c9430"><text class="info-label data-v-1f3c9430">教师：</text><text class="info-value data-v-1f3c9430">{{item.$orig.test&&item.$orig.test.teacherName||'-'}}</text></view></view><view class="exam-footer data-v-1f3c9430"><view class="score-info data-v-1f3c9430"><text class="score-label data-v-1f3c9430">成绩：</text><text class="{{['data-v-1f3c9430','score-value',item.m1]}}">{{''+(item.$orig.score||'-')+''}}</text></view><view class="action-area data-v-1f3c9430"><block wx:if="{{item.$orig.cheat===1}}"><text class="cheat-warning data-v-1f3c9430"> ⚠️ 作弊记录 </text></block><block wx:else><block wx:if="{{item.$orig.status!=='已批改'||!item.$orig.weatherCheck}}"><text class="disabled-text data-v-1f3c9430"> 暂不可查看 </text></block><block wx:else><text class="view-text data-v-1f3c9430"> 查看详情 → </text></block></block></view></view></view></block></view><block wx:if="{{total>pageSize}}"><view class="pagination data-v-1f3c9430"><button class="page-btn data-v-1f3c9430" disabled="{{pageNum===1}}" data-event-opts="{{[['tap',[['prevPage',['$event']]]]]}}" bindtap="__e"> 上一页 </button><text class="page-info data-v-1f3c9430">{{pageNum+" / "+totalPages}}</text><button class="page-btn data-v-1f3c9430" disabled="{{pageNum===totalPages}}" data-event-opts="{{[['tap',[['nextPage',['$event']]]]]}}" bindtap="__e"> 下一页 </button></view></block></view>